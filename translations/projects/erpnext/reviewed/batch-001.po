#. Content of the 'Help Text' (HTML) field in DocType 'Process Statement Of
#. Accounts'
#: erpnext/accounts/doctype/process_statement_of_accounts/process_statement_of_accounts.json
#, python-format
msgid "<br>\n"
"<h4>Note</h4>\n"
"<ul>\n"
"<li>\n"
"You can use <a href=\"https://jinja.palletsprojects.com/en/2.11.x/\" target=\"_blank\">Jinja tags</a> in <b>Subject</b> and <b>Body</b> fields for dynamic values.\n"
"</li><li>\n"
"    All fields in this doctype are available under the <b>doc</b> object and all fields for the customer to whom the mail will go to is available under the  <b>customer</b> object.\n"
"</li></ul>\n"
"<h4> Examples</h4>\n"
"<!-- {% raw %} -->\n"
"<ul>\n"
"    <li><b>Subject</b>:<br><br><pre><code>Statement Of Accounts for {{ customer.customer_name }}</code></pre><br></li>\n"
"    <li><b>Body</b>: <br><br>\n"
"<pre><code>Hello {{ customer.customer_name }},<br>PFA your Statement Of Accounts from {{ doc.from_date }} to {{ doc.to_date }}.</code> </pre></li>\n"
"</ul>\n"
"<!-- {% endraw %} -->"
msgstr "<br>\n"
"<h4>Observação</h4>\n"
"<ul>\n"
"<li>\n"
"Você pode usar <a href=\"https://jinja.palletsprojects.com/en/2.11.x/\" target=\"_blank\">tags Jinja</a> nos campos <b>Assunto</b> e <b>Corpo</b> para valores dinâmicos.\n"
"</li><li>\n"
"    Todos os campos deste doctype estão disponíveis no objeto <b>doc</b> e todos os campos do cliente que receberá o e-mail estão disponíveis no objeto <b>customer</b>.\n"
"</li></ul>\n"
"<h4> Exemplos</h4>\n"
"<!-- {% raw %} -->\n"
"<ul>\n"
"    <li><b>Assunto</b>:<br><br><pre><code>Extrato de contas de {{ customer.customer_name }}</code></pre><br></li>\n"
"    <li><b>Corpo</b>: <br><br>\n"
"<pre><code>Olá {{ customer.customer_name }},<br>Segue em anexo seu extrato de contas de {{ doc.from_date }} a {{ doc.to_date }}.</code> </pre></li>\n"
"</ul>\n"
"<!-- {% endraw %} -->"

