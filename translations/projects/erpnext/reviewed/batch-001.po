"&lt;p&gt;Requesting payment for {{ doc.doctype }}, {{ doc.name }} for {{ doc.grand_total }}.&lt;/p&gt;\n\n"
"&lt;a href=\"{{ payment_url }}\"&gt; click here to pay &lt;/a&gt;\n\n"
"</pre>\n"
msgstr "<pre><h5>Exemplo de mensagem</h5>\n\n&lt;p&gt;Prezado(a) {{ doc.contact_person }},&lt;/p&gt;\n\n&lt;p&gt;Solicitamos o pagamento de {{ doc.doctype }}, {{ doc.name }}, no valor de {{ doc.grand_total }}.&lt;/p&gt;\n\n&lt;a href=\"{{ payment_url }}\"&gt; clique aqui para pagar &lt;/a&gt;\n\n</pre>\n"

